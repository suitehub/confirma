rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // First Rule: Global Safety Net (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation helper for User document (blueprint constraints)
    function isValidUser(data) {
      return data.keys().hasAll(['updatedAt']) 
        && data.keys().size() <= 6
        && data.updatedAt is timestamp
        && (!data.keys().hasAny(['state']) || data.state is map)
        && (!data.keys().hasAny(['displayName']) || (data.displayName is string && data.displayName.size() <= 200))
        && (!data.keys().hasAny(['photoUrl']) || (data.photoUrl is string && data.photoUrl.size() <= 800000))
        && (!data.keys().hasAny(['isPaid']) || data.isPaid is bool)
        && (!data.keys().hasAny(['paidAt']) || data.paidAt is timestamp);
    }

    // Allow connection testing to the test/connection document (Phase 1)
    match /test/{docId} {
      allow get: if true;
    }

    // User workspace document isolation (Zero-Trust sandbox)
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
      
      allow create: if isSignedIn() 
        && isEmailVerified()
        && request.auth.uid == userId 
        && isValidId(userId)
        && isValidUser(incoming())
        && incoming().updatedAt == request.time;
        
      allow update: if isSignedIn() 
        && isEmailVerified()
        && request.auth.uid == userId 
        && isValidId(userId)
        && isValidUser(incoming())
        && (
          // Action 1: State Update (e.g., patient, agenda changes)
          (incoming().diff(existing()).affectedKeys().hasOnly(['state', 'updatedAt']) && incoming().updatedAt == request.time) ||
          // Action 2: Professional Profile update (e.g., photo, name changes)
          (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoUrl', 'updatedAt']) && incoming().updatedAt == request.time) ||
          // Action 3: Licensing (Simulated Paywall success update)
          (incoming().diff(existing()).affectedKeys().hasOnly(['isPaid', 'paidAt']))
        );
        
      allow delete: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
    }
  }
}
